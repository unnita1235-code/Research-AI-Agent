# Copy to .env and fill in values. Do not commit .env.
#
# LLM: anthropic (default) | heuristic (no LLM, only Tavily) | ollama (local, free)
# If you have no Anthropic credits, set: LLM_PROVIDER=heuristic
LLM_PROVIDER=heuristic

# Anthropic: https://console.anthropic.com/  (not needed when LLM_PROVIDER=heuristic)
ANTHROPIC_API_KEY=

# Tavily: https://tavily.com/
TAVILY_API_KEY=

# Ollama (only if LLM_PROVIDER=ollama): https://ollama.com
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# Web API (optional)
# ENABLE_SUGGEST_TOPICS=1
# ENABLE_EXECUTIVE_SUMMARY=0
# ENABLE_ASK=1
# ENABLE_COUNTERARGUMENTS=0
# ENABLE_TLDR=0
# ENABLE_TRANSLATE=0
# Job SQLite store (set 0 to disable)
# ENABLE_JOB_DB=1
# JOB_DB_PATH=./data/jobs.sqlite
# Per-IP limit for POST /research (0 = no limit)
# RATE_LIMIT_PER_MIN=0
